# PostgreSQL (Supabase, Neon, or local)
# Supabase direct host (db.*.supabase.co) is often IPv6-only. If you see getaddrinfo failed on Windows,
# use Session pooler from Dashboard → Connect → Session pooler (IPv4). Username is postgres.[PROJECT-REF].
# Replace [PROJECT-REF] and region with values from the dashboard (e.g. aws-1-us-east-1.pooler.supabase.com).
# DB password is case-sensitive and must match Project Settings → Database (reset there if auth fails).
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Optional: Ollama base URL (no trailing slash). If unset, LLM steps are skipped gracefully.
OLLAMA_HOST=http://localhost:11434

# Optional: St. Louis Fed FRED API key — required for the FRED unemployment source to fetch.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Frontend (Vercel) — public API URL for the FastAPI backend (Render or local).
NEXT_PUBLIC_API_URL=http://localhost:8000
