# Optional: St. Louis Fed FRED API key — required for the FRED unemployment source to fetch.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Frontend (Vercel) — public API URL for the FastAPI backend (Render or local).
NEXT_PUBLIC_API_URL=http://localhost:8000
