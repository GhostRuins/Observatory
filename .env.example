# PostgreSQL (Supabase, Neon, or local)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.mryeckcsdwowvtceraem.supabase.co:5432/postgres

# Optional: Ollama base URL (no trailing slash). If unset, LLM steps are skipped gracefully.
